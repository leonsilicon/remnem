{
  "name": "rmnm",
  "version": "0.1.0",
  "description": "Find and delete every nested node_modules in a project as fast as possible (napi-rs / Rust)",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "author": "Leon Si",
  "homepage": "https://github.com/leonsilicon/rmnm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonsilicon/rmnm.git"
  },
  "bugs": {
    "url": "https://github.com/leonsilicon/rmnm/issues"
  },
  "keywords": [
    "node_modules",
    "monorepo",
    "workspace",
    "clean",
    "cleaner",
    "delete",
    "napi-rs",
    "rust",
    "bun",
    "pnpm"
  ],
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "bin": {
    "rmnm": "bin/rmnm.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "bin/rmnm.js",
    "rmnm.darwin-universal.node",
    "README.md",
    "LICENSE"
  ],
  "napi": {
    "binaryName": "rmnm",
    "targets": [
      "universal-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --platform --release --target aarch64-apple-darwin && napi build --platform --release --target x86_64-apple-darwin && napi universalize",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi build --platform --release --target aarch64-apple-darwin && napi build --platform --release --target x86_64-apple-darwin && napi universalize",
    "test": "cargo test",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
